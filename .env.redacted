# Copy to .env and replace ****** with real values. Do not commit .env.
# Backend reads RAPIDAPI_JOBS_HOST (not RAPIDAPI_HOST) for Job Match.

PORT=3001
FRONTEND_URL=http://localhost:8080

# MySQL (Aiven) - set rejectUnauthorized=false for Aiven's cert chain
MYSQL_HOST=******
MYSQL_PORT=******
MYSQL_USER=******
MYSQL_PASSWORD=******
MYSQL_DATABASE=******
MYSQL_SSL_REJECT_UNAUTHORIZED=false

# JWT secret (change in production)
JWT_SECRET=******

# OpenAI (required for /api/generate/resume)
OPENAI_API_KEY=******
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=4000

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=******
SMTP_PASS=******
SMTP_FROM=******

# 32-byte hex OR passphrase (use one method; see .env.example)
ENCRYPTION_KEY=******

SEED_ADMIN_EMAIL=******

# RapidAPI – Active Jobs DB (Job Match)
RAPIDAPI_KEY=******
RAPIDAPI_JOBS_HOST=active-jobs-db.p.rapidapi.com
RAPIDAPI_JOBS_PATH=/active-ats-7d
RAPIDAPI_JOBS_LIMIT=15
RAPIDAPI_JOBS_OFFSET=0
RAPIDAPI_JOBS_DESCRIPTION_TYPE=text
