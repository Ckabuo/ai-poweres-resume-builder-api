# Server
PORT=3001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:8080

# MySQL
MYSQL_HOST=ai-powered-resume-builder-busybrainaf-cefa.j.aivencloud.com
MYSQL_PORT=10671
MYSQL_USER=avnadmin
MYSQL_PASSWORD=your-password
MYSQL_DATABASE=defaultdb

# JWT secret (change in production)
JWT_SECRET=your-secret-key

# OpenAI (required for /api/generate/resume)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=4000

# RapidAPI (for Job Match: AI-suggested jobs from saved resume)
# Get key: https://rapidapi.com/fantastic-jobs-fantastic-jobs-default/api/active-jobs-db
RAPIDAPI_KEY=your-rapidapi-key
# Host and path for Active Jobs DB (active-ats-7d endpoint)
RAPIDAPI_JOBS_HOST=active-jobs-db.p.rapidapi.com
RAPIDAPI_JOBS_PATH=/active-ats-7d
# Optional: limit (default 15), offset (default 0), description_type (default text)
# RAPIDAPI_JOBS_LIMIT=15
# RAPIDAPI_JOBS_OFFSET=0
# RAPIDAPI_JOBS_DESCRIPTION_TYPE=text

# Optional: promote this user to admin on startup (user must exist; sign up first)
# SEED_ADMIN_EMAIL=your@email.com

# Encryption at rest (NFR-3.1): 32-byte hex key or passphrase for AES-256-GCM
# Generate hex key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# SMTP (for password reset emails)
# Gmail: use App Password https://support.google.com/accounts/answer/185833
# SendGrid: host=smtp.sendgrid.net, port=587, user=apikey, pass=your-api-key
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourapp.com
