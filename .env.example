# Server
PORT=3001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:8080

# MySQL
MYSQL_HOST=ai-powered-resume-builder-busybrainaf-cefa.j.aivencloud.com
MYSQL_PORT=10671
MYSQL_USER=avnadmin
MYSQL_PASSWORD=your-password
MYSQL_DATABASE=defaultdb

# JWT secret (change in production)
JWT_SECRET=your-secret-key

# OpenAI (required for /api/generate/resume)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=4000

# Optional: promote this user to admin on startup (user must exist; sign up first)
# SEED_ADMIN_EMAIL=your@email.com

# Encryption at rest (NFR-3.1): 32-byte hex key or passphrase for AES-256-GCM
# Generate hex key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# SMTP (for password reset emails)
# Gmail: use App Password https://support.google.com/accounts/answer/185833
# SendGrid: host=smtp.sendgrid.net, port=587, user=apikey, pass=your-api-key
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourapp.com
